#!/bin/bash
{{ ansible_managed | comment }}

# tigervnc_session - Manage VNC session for a specific display
# This script determines the user for a given display and starts/stops the VNC server
# in that user's context with proper environment variables set.

PROG=$(basename "$0")
USERSFILE="/etc/tigervnc/vncserver.users"
WRAPPER="/usr/local/bin/tigervnc_wrapper"

usage() {
    echo "Usage: $PROG [-kill] DISPLAY"
    echo "  DISPLAY: Display number (e.g., 1, 2, 3)"
    echo "  -kill: Kill the VNC server instead of starting it"
    exit 1
}

# Parse arguments
KILL_MODE=0
VNC_DISPLAY=""

while [ $# -gt 0 ]; do
    case "$1" in
        -kill)
            KILL_MODE=1
            shift
            ;;
        *)
            VNC_DISPLAY="$1"
            shift
            ;;
    esac
done

# Validate display argument
if [ -z "$VNC_DISPLAY" ]; then
    echo "$PROG: No display number specified" >&2
    usage
fi

# Remove leading colon if present
VNC_DISPLAY="${VNC_DISPLAY#:}"

# Check if vncserver.users file exists
if [ ! -f "$USERSFILE" ]; then
    echo "$PROG: User mapping file not found: $USERSFILE" >&2
    exit 1
fi

# Find the user for this display
USER=$(grep "^[[:space:]]*:${VNC_DISPLAY}=" "$USERSFILE" | head -1 | cut -d= -f2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

if [ -z "$USER" ]; then
    echo "$PROG: No user configured for display :$VNC_DISPLAY in $USERSFILE" >&2
    exit 1
fi

# Verify user exists on the system
if ! id "$USER" >/dev/null 2>&1; then
    echo "$PROG: User '$USER' does not exist on this system" >&2
    exit 1
fi

# Execute the wrapper as the target user via a clean transient systemd unit.
# systemd-run provides a fully isolated environment (clean env, PAM session)
# PAMName=tigervnc uses TigerVNC's own /etc/pam.d/tigervnc service definition
# rather than the console-login PAM stack, avoiding unintended capabilities
# from admin customisations to /etc/pam.d/login.
# /bin/sh -l opens a POSIX login shell so that /etc/profile and
# /etc/profile.d/*.sh (as well as ~/.profile) are sourced before the wrapper
# runs. The immediate exec replaces the shell process with the wrapper, so no
# extra shell process is left running.
if [ $KILL_MODE -eq 1 ]; then
    exec systemd-run --uid="$USER" --wait --pty --collect \
        --property=PAMName=tigervnc \
        /bin/sh -l -c "exec \"$WRAPPER\" -kill \":$VNC_DISPLAY\""
else
    exec systemd-run --uid="$USER" --wait --pty --collect \
        --property=PAMName=tigervnc \
        /bin/sh -l -c "exec \"$WRAPPER\" \":$VNC_DISPLAY\" -fg"
fi
